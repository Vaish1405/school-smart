PORT=3000

# Required
IBM_ORCHESTRA_API_URL=https://your-orchestra-api-endpoint
IBM_ORCHESTRA_API_KEY=your_ibm_cloud_api_key

# Recommended (based on IBM custom UI integration pattern)
IBM_ORCHESTRA_USE_IAM=true
IBM_ORCHESTRA_IAM_TOKEN_URL=https://iam.cloud.ibm.com/identity/token

# Optional routing hints for your deployed agent
IBM_ORCHESTRA_AGENT_ID=f39a2000-f7c6-49c4-8018-6c175715f4ff
IBM_ORCHESTRA_AGENT_ENV_ID=9c35af4e-5afc-41b6-9db7-535c5d88ae9b
IBM_ORCHESTRA_ORCHESTRATION_ID=74a2f9840fef429b8a3dfe1ca89069b1_e7380f9b-2bfd-4aa2-b4d8-0e9382c8c76d

# Optional
IBM_ORCHESTRA_TIMEOUT_MS=20000

# Optional: enable local simulation for UI demos
IBM_ORCHESTRA_SIMULATE=false
