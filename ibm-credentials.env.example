PORT=3000

# Required for custom "AI Study Helper" (top-right panel)
GEMINI_API_KEY=your_gemini_api_key

# Optional Gemini settings
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=45000
GEMINI_MAX_ATTACHMENTS=8
GEMINI_MAX_FILE_BYTES=7000000

# Optional: IBM embedded chat metadata (left-side embedded widget in index.html)
# These values are currently wired directly in index.html for the IBM script embed.
# Keep here for reference / future server-side use if needed.
IBM_ORCHESTRA_AGENT_ID=f39a2000-f7c6-49c4-8018-6c175715f4ff
IBM_ORCHESTRA_AGENT_ENV_ID=9c35af4e-5afc-41b6-9db7-535c5d88ae9b
